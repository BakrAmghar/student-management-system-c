  <property name="styleSheet">
   <string notr="true">/* The Background */
QMainWindow {
    background-color: #1e272e; /* Dark professional blue-grey */
}

/* Group Boxes (Add, Search, Delete) */
QGroupBox {
    color: #ffffff;
    font-weight: bold;
    border: 2px solid #34495e;
    border-radius: 8px;
    margin-top: 15px;
    padding-top: 10px;
}

/* THE FIX: Input Fields */
QLineEdit {
    background-color: #ffffff; /* White background for visibility */
    color: #2c3e50;            /* Dark text so you can see it! */
    border: 1px solid #dcdde1;
    border-radius: 4px;
    padding: 5px;
    font-size: 14px;
}

QLineEdit:focus {
    border: 2px solid #3498db;
    background-color: #f7f9fb;
}

/* Labels */
QLabel {
    color: #dcdde1;
    font-size: 13px;
    font-weight: bold;
}

/* List Boxes (Students and Stats) */
QListWidget {
    background-color: #2f3640;
    border: 1px solid #34495e;
    border-radius: 8px;
    color: #f5f6fa;
    padding: 10px;
}

/* Buttons */
QPushButton {
    background-color: #3498db;
    color: white;
    border-radius: 5px;
    padding: 8px;
    font-weight: bold;
    font-size: 13px;
}

QPushButton:hover {
    background-color: #2980b9;
}

/* Color Coding for Buttons */
#btn_save { background-color: #27ae60; }
#btn_save:hover { background-color: #219150; }

#btn_delete { background-color: #c0392b; }
#btn_delete:hover { background-color: #a93226; }</string>
  </property>
  <widget class="QWidget" name="centralwidget">
   <property name="styleSheet">
    <string notr="true">/* This styles the main background */
QMainWindow {
    background-color: #f5f6fa;
}

/* This styles ALL buttons at once */
QPushButton {
    background-color: #353b48;
    color: white;
    border-radius: 6px;
    padding: 8px;
    font-size: 13px;
    font-weight: bold;
}

/* This makes buttons change color when you hover over them */
QPushButton:hover {
    background-color: #718093;
}

/* This styles the input boxes */
QLineEdit {
    border: 2px solid #dcdde1;
    border-radius: 5px;
    padding: 4px;
    background-color: white;
}

/* This makes the input box border blue when you click inside it */
QLineEdit:focus {
    border: 2px solid #0097e6;
}</string>
